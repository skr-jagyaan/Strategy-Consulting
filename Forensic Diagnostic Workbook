          {menuItems.map((_, index) => (
            <div 
              key={index} 
              className={`${activeTab === index ? 'block' : 'hidden'} print:block print:break-after-page`}
            >
              {renderContent(index)}
            </div>
          ))}
        </div>

        {/* Print Only Footer */}
        <div className="hidden print:block fixed bottom-0 left-0 right-0 p-4 text-center text-xs text-slate-400 border-t border-slate-200">
          Generated via Forensic Diagnostic Tool • Confidential Strategy Document
        </div>
      </div>
      
      {/* Mobile Nav Overlay could go here */}
    </div>
  );

                 By stopping these activities, we free up approximately <input className="border-b border-indigo-300 bg-transparent w-24 text-center font-bold text-indigo-900 outline-none" placeholder="₹ Amount" /> and <input className="border-b border-indigo-300 bg-transparent w-24 text-center font-bold text-indigo-900 outline-none" placeholder="Hours" /> hours per month.
               </p>
             </div>

             <div className="border-2 border-slate-900 p-8 rounded-lg mt-12 bg-white relative">
               <div className="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-white px-4">
                 <span className="text-slate-900 font-bold uppercase tracking-widest text-sm border border-slate-900 px-2 py-1">Official Sign-Off</span>
               </div>
               <p className="text-center italic text-slate-700 mb-8 mt-4 font-serif text-lg">
                 "I certify that the diagnosis above is a true and accurate reflection of our current reality. I am committed to fixing the root causes identified in this document."
               </p>
               <div className="flex flex-col md:flex-row justify-between gap-8 mt-12">
                 <div className="flex-1">
                   <div className="border-b-2 border-slate-900 mb-2"></div>
                   <p className="text-xs uppercase font-bold text-slate-500">Founder's Signature</p>
                 </div>
                 <div className="w-48">
                   <div className="border-b-2 border-slate-900 mb-2"></div>
                   <p className="text-xs uppercase font-bold text-slate-500">Date</p>
                 </div>
               </div>
             </div>
          </SectionCard>
        );

      default:
        return null;
    }
  }

  return (
    <div className="min-h-screen bg-slate-100 text-slate-900 font-sans print:bg-white">
      {/* Sidebar - Hidden on Print */}
      <div className="fixed left-0 top-0 bottom-0 w-64 bg-slate-900 text-white p-6 hidden md:flex flex-col print:hidden">
        <div className="mb-8 flex items-center gap-2">
          <div className="w-8 h-8 bg-indigo-500 rounded-lg flex items-center justify-center font-bold text-xl">F</div>
          <h1 className="font-bold text-lg tracking-tight">Forensic Diagnostic</h1>
        </div>
        
        <nav className="flex-1 overflow-y-auto space-y-1 custom-scrollbar">
          {menuItems.map((item, index) => {
            const Icon = item.icon;
            return (
              <button
                key={index}
                onClick={() => setActiveTab(index)}
                className={`w-full flex items-center gap-3 px-4 py-3 rounded-lg text-sm transition-all ${
                  activeTab === index 
                    ? 'bg-indigo-600 text-white font-medium shadow-lg' 
                    : 'text-slate-400 hover:bg-slate-800 hover:text-white'
                }`}
              >
                <Icon size={18} />
                {item.title}
                {activeTab === index && <ChevronRight size={14} className="ml-auto" />}
              </button>
            )
          })}
        </nav>

        <div className="pt-6 mt-6 border-t border-slate-800">
           <button 
             onClick={handlePrint}
             className="w-full flex items-center justify-center gap-2 bg-white text-slate-900 py-2 rounded font-bold hover:bg-indigo-50 transition-colors"
